<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.enterprise.agent</groupId>
        <artifactId>eap-engine</artifactId>
        <version>1.0.0-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>eap-engine-llm</artifactId>
    <name>EAP Engine LLM</name>
    <description>引擎层-LLM：Spring AI 多模型热切换 + @Cacheable LLM 响应缓存</description>

    <dependencies>
        <dependency>
            <groupId>com.enterprise.agent</groupId>
            <artifactId>eap-common</artifactId>
        </dependency>

        <!-- Spring AI - OpenAI（默认 provider，必选） -->
        <dependency>
            <groupId>org.springframework.ai</groupId>
            <artifactId>spring-ai-starter-model-openai</artifactId>
        </dependency>

        <!--
          Anthropic / Ollama starter 不在此处引入。
          ChatModelConfig 改为通过 ApplicationContext.getBean(beanName) 懒查找，
          无需对可选 starter 中的类有任何字节码级引用。
          需要切换 provider 时，在 eap-app/pom.xml 引入对应 starter 即可。
        -->
        <!-- @Cacheable 注解支持（CacheManager bean 由 eap-app 的 RedisConfig 提供） -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-cache</artifactId>
        </dependency>

        <!-- Spring AI Retry 依赖（SpringAiRetryAutoConfiguration 需要） -->
        <dependency>
            <groupId>org.springframework.retry</groupId>
            <artifactId>spring-retry</artifactId>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-autoconfigure</artifactId>
        </dependency>
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>
    </dependencies>
</project>
